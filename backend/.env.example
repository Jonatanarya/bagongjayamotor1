# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/bagong_jaya_motor
DB_LOGGING=false

# Auth (Better Auth)
AUTH_URL=https://api.yourdomain.com
AUTH_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_32_CHARS
AUTH_BASE_URL=https://api.yourdomain.com/api/auth

# Server
NODE_ENV=production
PORT=3000

# CORS - comma separated allowed origins
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com,https://admin.yourdomain.com

# File Upload
MAX_FILE_SIZE=2097152
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info
